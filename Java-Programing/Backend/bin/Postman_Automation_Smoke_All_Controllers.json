                "employer",
                "applications",
                "does-not-exist",
                "accept"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response time < 500ms', () => pm.expect(responseTime).to.be.below(500));",
                  "pm.test('Status 500 or 403', () => pm.expect([403,500]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
